{
    "name": "survos/settings-bundle",
    "description": "Tenant-scoped settings storage for Symfony applications.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "symfony",
        "settings",
        "tenant",
        "scope",
        "configuration"
    ],
    "autoload": {
        "psr-4": {
            "Survos\\SettingsBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Survos\\SettingsBundle\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.4",
        "doctrine/dbal": "^4.2",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/orm": "^3.6",
        "survos/kit-bundle": "^2.5",
        "symfony/dependency-injection": "^8.1",
        "symfony/form": "^8.1",
        "symfony/http-kernel": "^8.1",
        "symfony/security-csrf": "^8.1",
        "symfony/twig-bundle": "^8.1",
        "symfony/uid": "^8.1",
        "symfony/ux-live-component": "^3.0",
        "symfony/validator": "^8.1",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "extra": {
        "symfony": {
            "require": "^8.1"
        }
    }
}
